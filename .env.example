# Discord
DISCORD_BOT_TOKEN=replace-me
# Optional if the bot is in exactly one guild:
# DISCORD_GUILD_ID=123456789012345678
DISCORD_ALLOWED_USER_IDS=replace-with-your-user-id
# DISCORD_PROJECTS_CATEGORY_NAME=codex-projects
# WORKSPACE_ROOT=/Users/you/projects
# Legacy aliases still accepted:
# PROJECTS_ROOT=/Users/you/projects
# DISCORD_REPO_ROOT=/Users/you/projects
# DISCORD_GENERAL_CHANNEL_ID=
# DISCORD_GENERAL_CHANNEL_NAME=general
# DISCORD_GENERAL_CWD=/tmp/agent-gateway/general

# Feishu / Lark
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=replace-me
# Optional transport selector: webhook (default) or long-connection
# FEISHU_TRANSPORT=webhook
# Optional webhook validation:
# FEISHU_VERIFICATION_TOKEN=replace-me
# Optional allowlist:
# FEISHU_ALLOWED_OPEN_IDS=ou_xxx
# FEISHU_GENERAL_CHAT_ID=oc_xxx
# FEISHU_GENERAL_CWD=/tmp/agent-gateway/feishu-general
# FEISHU_REQUIRE_MENTION_IN_GROUP=1
# FEISHU_LOG_INGRESS=1
# FEISHU_SEGMENTED_STREAMING=1
# FEISHU_STREAM_MIN_CHARS=80
# FEISHU_UNBOUND_CHAT_MODE=open
# FEISHU_UNBOUND_CHAT_CWD=/Users/you/projects/default-repo
# FEISHU_WEBHOOK_PATH=/feishu/events

# Backend HTTP
# BACKEND_HTTP_ENABLED=1
# BACKEND_HTTP_HOST=0.0.0.0
# BACKEND_HTTP_PORT=8788

# Codex runtime
# CODEX_BIN=codex
# CODEX_HOME=
# CODEX_APPROVAL_POLICY=never
# CODEX_SANDBOX_MODE=workspace-write
# CODEX_EXTRA_WRITABLE_ROOTS=/absolute/path/one:/absolute/path/two

# Config and state
# CHANNEL_CONFIG_PATH=./config/channels.json
# STATE_PATH=./data/state.json
# DISCORD_HEARTBEAT_PATH=./data/bridge-heartbeat.json
# DISCORD_HEARTBEAT_INTERVAL_MS=30000
# DISCORD_RESTART_REQUEST_PATH=./data/restart-request.json
# DISCORD_RESTART_ACK_PATH=./data/restart-ack.json
# DISCORD_RESTART_NOTICE_PATH=./data/restart-discord-notice.json
# DISCORD_INFLIGHT_RECOVERY_PATH=./data/inflight-turns.json
# TURN_RECOVERY_NOTIFY=1
# TURN_REQUEST_STATUS_TTL_MS=259200000
# TURN_REQUEST_STATUS_MAX_RECORDS=5000
# TURN_REQUEST_STATUS_MAX_PER_THREAD=300
# DISCORD_EXIT_ON_RESTART_ACK=0
# DISCORD_SELF_RESTART_ON_REQUEST defaults to 1 when DISCORD_EXIT_ON_RESTART_ACK=0,
# and defaults to 0 when DISCORD_EXIT_ON_RESTART_ACK=1 (host-managed restart mode).
# DISCORD_SELF_RESTART_ON_REQUEST=1

# Attachments and rendering
# DISCORD_IMAGE_CACHE_DIR=/tmp/agent-gateway-images
# DISCORD_MAX_IMAGES_PER_MESSAGE=4
# Discord message chunk size (keep <= 1900 for Discord compatibility).
# DISCORD_MESSAGE_CHUNK_LIMIT=1900
# Feishu text chunk size (can be larger than Discord).
# FEISHU_MESSAGE_CHUNK_LIMIT=8000
# DISCORD_ENABLE_ATTACHMENTS=1
# DISCORD_LOG_ATTACHMENTS=1
# DISCORD_ATTACHMENT_INFER_FROM_TEXT=0
# DISCORD_MAX_ATTACHMENT_ISSUES_PER_TURN=1
# DISCORD_ATTACHMENT_MAX_BYTES=8388608
# DISCORD_ATTACHMENT_ROOTS=/tmp:/absolute/path/attachments
# DISCORD_ATTACHMENT_ITEM_TYPES=imageView,toolCall,mcpToolCall,commandExecution
# DISCORD_TURN_MAX_DURATION_MS=1800000
# DISCORD_RENDER_VERBOSITY=user
# Set to 1 to disable incremental streaming and only send final answers.
# DISABLE_STREAMING_OUTPUT=0
# DISCORD_STRIP_ANSI_OUTPUT=0
# DISCORD_DEBUG_LOGGING=1

# Logs and service helpers
# DISCORD_STDOUT_LOG_PATH=/tmp/agent-gateway.out.log
# DISCORD_STDERR_LOG_PATH=/tmp/agent-gateway.err.log
# DISCORD_LAUNCHD_LABEL=com.agent.gateway

# Optional outbound proxy
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
